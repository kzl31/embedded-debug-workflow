{
  "version": 2,
  "description": "Flow Gate 阶段注册中心 — 唯一权威来源，新增阶段只需在此注册 + 创建门禁文件",
  "phases": {
    "STARTUP": {
      "gateFile": "gates/STARTUP.yaml",
      "description": "启动阶段 — 读取配置、采集参数、确认硬件就绪",
      "forbiddenOperations": ["git_log", "git_diff", "analyze_code", "compile", "flash"],
      "nextPhase": "DEBUG_LOOP"
    },
    "DEBUG_LOOP": {
      "gateFile": "gates/DEBUG_LOOP.yaml",
      "description": "调试循环 — CHESHI 迭代、编译下载、日志分析（上限 8 轮）",
      "forbiddenOperations": ["generate_report"],
      "nextPhase": "VERIFY_AND_REPORT"
    },
    "VERIFY_AND_REPORT": {
      "gateFile": "gates/VERIFY_AND_REPORT.yaml",
      "description": "验证与报告 — 清理 CHESHI、回归验证、生成总结报告",
      "forbiddenOperations": ["add_cheshi"],
      "nextPhase": "COMPLETED",
      "onComplete": "generate_report_and_memory"
    },
    "COMPLETED": {
      "gateFile": null,
      "description": "已完成 — 允许任意操作",
      "forbiddenOperations": [],
      "nextPhase": null
    }
  }
}
